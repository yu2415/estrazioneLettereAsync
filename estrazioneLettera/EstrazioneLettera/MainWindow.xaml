<Window x:Class="estrazioneLettere_ProgrammazioneAsincrona.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:estrazioneLettere_ProgrammazioneAsincrona"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button x:Name="btnEstrazione" Content="ESTRAI" HorizontalAlignment="Left" Height="214" Margin="26,181,0,0" VerticalAlignment="Top" Width="336" Click="btnEstrazione_Click" FontSize="40"/>
        <TextBox x:Name="txtBoxNumeriEstratti" HorizontalAlignment="Left" Height="166" Margin="26,10,0,0" TextWrapping="Wrap" Text="Inserire il numero delle lettere che si vuole estrarre da 1 a 20" VerticalAlignment="Top" Width="168" FontSize="20"/>
        <Button Content="Conferma numero" HorizontalAlignment="Left" Height="166" Margin="194,10,0,0" VerticalAlignment="Top" Width="168" Click="NumeroLettere_Click" FontSize="20"/>
        <ListBox x:Name="lbxLettereEstratte" HorizontalAlignment="Left" Height="385" Margin="376,10,0,0" VerticalAlignment="Top" Width="414"/>

    </Grid>
</Window>